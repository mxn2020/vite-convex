{
  "name": "vite-convex-scaffold",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Minimal Vite + React + Convex project scaffold template for rapid app creation",
  "author": "Mehdi Nabhani <mehdi@geenius.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mxn2020/vite-convex.git"
  },
  "keywords": [
    "vite",
    "react",
    "convex",
    "scaffold",
    "template",
    "boilerplate"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "prettier --check '**/*' --ignore-unknown",
    "lint:eslint": "eslint .",
    "format": "prettier --write '**/*' --ignore-unknown",
    "test": "vitest run",
    "test:run": "vitest run",
    "stop": "pkill -f 'vite.*vite-convex' || true"
  },
  "dependencies": {
    "@auth/core": "0.37.0",
    "@convex-dev/auth": "^0.0.91",
    "@geenius-ui/react": "^0.1.2",
    "@vercel/analytics": "^1.6.1",
    "convex": "^1.32.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}